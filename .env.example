# Vorlage für .env — echte Werte NICHT hier eintragen, sondern in .env (gitignored).
# Kopieren mit:  cp .env.example .env  und Werte ausfüllen.

# Google API
GOOGLE_CLOUD_STORAGE_BUCKET=
# Pfad zur Earth-Engine-Dienstkonto-JSON (Datei selbst gehört unter secrets/, gitignored).
GOOGLE_APPLICATION_CREDENTIALS=./secrets/ee-service-account.json

# Copernicus Data Space Ecosystem (Sentinel Hub / Statistical API)
# OAuth-Client: dataspace.copernicus.eu → User Settings → OAuth clients.
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# OpenWeatherMap
OPENWEATHERMAP_API_KEY=

# HETZNER API (Cloud-Token; deckt AUCH DNS ab → api.hetzner.cloud/v1/zones, Zone doldenblick.de=1421900)
HETZNER_API_TOKEN=

# Postmark (transaktionaler E-Mail-Versand), Server doldenblick.de (DKIM/Return-Path verifiziert).
# SERVER-Token = SMTP-User UND -Passwort (smtp.postmarkapp.com:587 STARTTLS, From noreply@doldenblick.de).
POSTMARK_SERVER_API_TOKEN=
# ACCOUNT-Token: Domain-/Signatur-Verwaltung + DKIM/Return-Path-Verifikation (kein Versand).
POSTMARK_ACCOUNT_API_TOKEN=
